{
  "name": "cathode-terminal",
  "version": "1.0.0",
  "description": "Split chat + browser dev tool for Claude Code",
  "//": "zod has no direct imports \u2014 it satisfies @agentclientprotocol/sdk peerDependency. Do not remove.",
  "author": "hplan",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.25.0",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "gsap": "^3.15.0",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.cathode.terminal",
    "productName": "Cathode Terminal",
    "copyright": "Copyright \u00a9 2025",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.png",
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!**/*.md",
      "!**/*.map",
      "!**/*.ts",
      "!**/.git/**/*",
      "!node_modules/monaco-editor/dev/**",
      "!node_modules/monaco-editor/esm/**",
      "!node_modules/monaco-editor/min-maps/**",
      "!node_modules/node-pty/prebuilds/darwin-arm64/**",
      "!node_modules/node-pty/prebuilds/darwin-x64/**",
      "!node_modules/node-pty/prebuilds/win32-arm64/**"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
