{
  "name": "cathode-terminal",
  "version": "1.0.14",
  "description": "Split chat + browser dev tool for AI coding agents",
  "//": "zod has no direct imports — it satisfies @agentclientprotocol/sdk peerDependency. Do not remove.",
  "author": "hplan",
  "license": "MIT",
  "homepage": "https://github.com/hplant6/cathode-terminal#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/hplant6/cathode-terminal.git"
  },
  "bugs": {
    "url": "https://github.com/hplant6/cathode-terminal/issues"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win --x64 --publish never",
    "dist:win": "electron-builder --win --x64 --publish never",
    "dist:mac": "electron-builder --mac --arm64 --x64 --publish never",
    "dist:linux": "electron-builder --linux --x64 --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.25.0",
    "@jaames/iro": "^5.5.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.9",
    "gsap": "^3.15.0",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^41.9.2",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.cathode.terminal",
    "productName": "Cathode Terminal",
    "copyright": "Copyright © 2025",
    "afterSign": "scripts/notarize.js",
    "afterPack": "scripts/adhoc-sign.js",
    "publish": {
      "provider": "github",
      "owner": "hplant6",
      "repo": "cathode-terminal"
    },
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "main.js",
      "icon.png",
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!**/*.md",
      "!**/*.map",
      "!**/*.ts",
      "!**/.git/**/*",
      "!node_modules/monaco-editor/dev/**",
      "!node_modules/monaco-editor/esm/**",
      "!node_modules/monaco-editor/min-maps/**"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "win": {
      "files": [
        "!node_modules/node-pty/prebuilds/darwin-*/**"
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "files": [
        "!node_modules/node-pty/prebuilds/win32-*/**"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "notarize": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "files": [
        "!node_modules/node-pty/prebuilds/darwin-*/**",
        "!node_modules/node-pty/prebuilds/win32-*/**"
      ],
      "category": "Development",
      "icon": "icon.png",
      "synopsis": "Split chat + browser dev tool for AI coding agents",
      "maintainer": "hplan <hplant6@users.noreply.github.com>",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "${name}-Setup-${version}.${ext}"
    }
  }
}
